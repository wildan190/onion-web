---
import Layout from '../layouts/Layout.astro';

const buildDate = new Intl.DateTimeFormat('id-ID', {
	weekday: 'long',
	year: 'numeric',
	month: 'long',
	day: 'numeric',
}).format(new Date());

const priceRows = [
	{ grade: 'Besar', berat: '1 kg', harga: 'Rp 35.000' },
	{ grade: 'Sedang', berat: '1 kg', harga: 'Rp 28.000' },
	{ grade: 'Kecil', berat: '1 kg', harga: 'Rp 22.000' },
];
---

<Layout
	title={`Info Harga Bawang Merah 1 kg Hari ini — ${buildDate} | mitrabawang.id`}
	description="Info harga bawang merah per kg hari ini di mitrabawang.id. Update harian pkl. 10.30 WIB. Grade besar, sedang, kecil."
>
	<div class="page-shell price-page">
		<h1 class="price-page__title">
			Info Harga Bawang Merah 1 kg Hari ini
			<span class="price-page__date" id="page-date">{buildDate}</span>
		</h1>
		<p class="price-page__meta">Harga bawang merah di-update setiap hari pkl. 10.30 WIB</p>

		<div class="price-table-wrap">
			<table class="price-table">
				<caption class="sr-only">Harga bawang merah per 1 kg berdasarkan grade</caption>
				<thead>
					<tr>
						<th scope="col">Grade</th>
						<th scope="col">Berat</th>
						<th scope="col">Harga</th>
					</tr>
				</thead>
				<tbody>
					{
						priceRows.map(({ grade, berat, harga }) => (
							<tr>
								<td>{grade}</td>
								<td>{berat}</td>
								<td class="price-table__amount">{harga}</td>
							</tr>
						))
					}
				</tbody>
			</table>
		</div>

		<div class="price-cta">
			<p class="price-cta__text">
				Ingin membeli bawang merah langsung dari supplier tangan pertama dengan harga grosir? Kunjungi halaman ini:
			</p>
			<a class="price-cta__link" href="/">Jual Bawang Merah Grosir</a>
		</div>

		<p class="price-page__back">
			<a href="/">← Kembali ke beranda</a>
		</p>
	</div>
</Layout>

<script is:inline>
	function formatIdDate(d) {
		return new Intl.DateTimeFormat('id-ID', {
			weekday: 'long',
			year: 'numeric',
			month: 'long',
			day: 'numeric',
		}).format(d);
	}
	var el = document.getElementById('page-date');
	if (el) el.textContent = formatIdDate(new Date());
	document.title =
		'Info Harga Bawang Merah 1 kg Hari ini — ' + formatIdDate(new Date()) + ' | mitrabawang.id';
</script>

<style>
	.price-page__title {
		margin-bottom: 0.5rem;
	}

	.price-page__date {
		display: block;
		font-size: clamp(1rem, 2.8vw, 1.2rem);
		font-weight: 700;
		color: var(--color-accent);
		margin-top: 0.4rem;
		line-height: 1.3;
	}

	@media (min-width: 640px) {
		.price-page__date {
			display: inline;
			margin-top: 0;
			margin-left: 0.35rem;
		}
	}

	.price-page__meta {
		margin: 0 0 1.5rem;
		font-size: 1.05rem;
		color: var(--color-muted);
		max-width: 36rem;
	}

	.price-table-wrap {
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: var(--radius);
		box-shadow: var(--shadow);
		overflow: hidden;
		margin-bottom: 1.75rem;
	}

	.price-table {
		width: 100%;
		border-collapse: collapse;
		font-size: 1.02rem;
	}

	.price-table caption.sr-only {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border: 0;
	}

	.price-table thead {
		background: linear-gradient(180deg, #fce7f3 0%, #fdf2f8 100%);
	}

	.price-table th {
		text-align: left;
		padding: 0.85rem 1.15rem;
		font-size: 0.72rem;
		font-weight: 800;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: #881337;
		border-bottom: 2px solid rgba(159, 18, 57, 0.2);
	}

	.price-table td {
		padding: 0.95rem 1.15rem;
		color: var(--color-muted);
		border-bottom: 1px solid var(--color-border);
	}

	.price-table tbody tr:last-child td {
		border-bottom: none;
	}

	.price-table tbody tr:nth-child(even) {
		background: #fafaf9;
	}

	.price-table__amount {
		font-weight: 800;
		color: var(--color-text);
		font-variant-numeric: tabular-nums;
	}

	.price-cta {
		background: linear-gradient(135deg, #fffbeb 0%, #fff 55%);
		border: 1px solid rgba(217, 119, 6, 0.22);
		border-radius: var(--radius);
		padding: 1.25rem 1.35rem;
		margin-bottom: 1.5rem;
	}

	.price-cta__text {
		margin: 0 0 1rem;
		color: var(--color-text);
		line-height: 1.6;
		font-size: 1.02rem;
	}

	.price-cta__link {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.65rem 1.2rem;
		font-weight: 700;
		font-size: 0.98rem;
		color: #fff;
		background: var(--color-accent);
		border-radius: 10px;
		text-decoration: none;
		transition: background 0.15s ease, transform 0.15s ease;
	}

	.price-cta__link:hover {
		background: #881337;
		color: #fff;
	}

	.price-cta__link:active {
		transform: scale(0.99);
	}

	.price-page__back {
		margin: 0;
	}

	.price-page__back a {
		font-weight: 600;
		text-decoration: none;
	}

	@media (prefers-reduced-motion: reduce) {
		.price-cta__link:active {
			transform: none;
		}
	}
</style>

---
import Layout from '../layouts/Layout.astro';
import JsonLd from '../components/JsonLd.astro';
import {
	logoUrl,
	orgId,
	postalAddressBlock,
	sameAsProfiles,
	siteEmail,
	siteOrigin,
	siteTelephoneE164,
} from '../data/schema-site';

const buildDate = new Intl.DateTimeFormat('id-ID', {
	timeZone: 'Asia/Jakarta',
	weekday: 'long',
	year: 'numeric',
	month: 'long',
	day: 'numeric',
}).format(new Date());

const priceRows = [
	{ grade: 'Besar', berat: '1 kg', harga: 'Rp 34.500', priceValue: '34500', sku: 'BM-BESAR-1KG' },
	{ grade: 'Sedang', berat: '1 kg', harga: 'Rp 28.200', priceValue: '28200', sku: 'BM-SEDANG-1KG' },
	{ grade: 'Kecil', berat: '1 kg', harga: 'Rp 22.000', priceValue: '22000', sku: 'BM-KECIL-1KG' },
];

const origin = siteOrigin(Astro.site);
const organizationRef = orgId(origin);
const priceValidUntil = new Date();
priceValidUntil.setDate(priceValidUntil.getDate() + 14);
const priceValidUntilStr = priceValidUntil.toISOString().slice(0, 10);

const whatsappHref = 'https://wa.me/6281233624549';

const priceStructuredData = {
	'@context': 'https://schema.org',
	'@graph': [
		{
			'@type': 'Organization',
			'@id': organizationRef,
			name: 'mitrabawang.id',
			url: `${origin}/`,
			logo: logoUrl(origin),
			email: siteEmail,
			telephone: siteTelephoneE164,
			address: postalAddressBlock(),
			sameAs: [...sameAsProfiles],
		},
		{
			'@type': 'Product',
			'@id': `${origin}/harga-bawang-merah-hari-ini#bawang-merah-besar`,
			name: 'Bawang Merah Besar 1 kg',
			description: 'Bawang merah grade besar berkualitas tinggi, daya simpan hingga 6 bulan.',
			sku: 'BM-BESAR-1KG',
			brand: { '@id': organizationRef },
			category: 'Fresh produce — red onion / shallot',
			image: logoUrl(origin),
			offers: {
				'@type': 'Offer',
				price: '34500',
				priceCurrency: 'IDR',
				priceValidUntil: priceValidUntilStr,
				availability: 'https://schema.org/InStock',
				seller: { '@id': organizationRef },
			},
		},
		{
			'@type': 'Product',
			'@id': `${origin}/harga-bawang-merah-hari-ini#bawang-merah-sedang`,
			name: 'Bawang Merah Sedang 1 kg',
			description: 'Bawang merah grade sedang berkualitas tinggi, daya simpan hingga 6 bulan.',
			sku: 'BM-SEDANG-1KG',
			brand: { '@id': organizationRef },
			category: 'Fresh produce — red onion / shallot',
			image: logoUrl(origin),
			offers: {
				'@type': 'Offer',
				price: '28200',
				priceCurrency: 'IDR',
				priceValidUntil: priceValidUntilStr,
				availability: 'https://schema.org/InStock',
				seller: { '@id': organizationRef },
			},
		},
		{
			'@type': 'Product',
			'@id': `${origin}/harga-bawang-merah-hari-ini#bawang-merah-kecil`,
			name: 'Bawang Merah Kecil 1 kg',
			description: 'Bawang merah grade kecil berkualitas tinggi, daya simpan hingga 6 bulan.',
			sku: 'BM-KECIL-1KG',
			brand: { '@id': organizationRef },
			category: 'Fresh produce — red onion / shallot',
			image: logoUrl(origin),
			offers: {
				'@type': 'Offer',
				price: '22000',
				priceCurrency: 'IDR',
				priceValidUntil: priceValidUntilStr,
				availability: 'https://schema.org/InStock',
				seller: { '@id': organizationRef },
			},
		},
	],
};
---

<Layout
	title="Info Harga Bawang Merah 1 kg Hari ini"
	description={`Informasi harga bawang merah per kg hari ini. Update setiap hari pkl. 10.30 WIB. Grade besar, sedang, kecil.`}
>
	<div class="page-shell price-page">
		<h1 class="price-page__title">
			Info Harga Bawang Merah 1 kg Hari ini
			<span class="price-page__date" id="page-date">{buildDate}</span>
		</h1>
		<p class="price-page__meta">Harga bawang merah (brambang) terakhir diperbarui: <span id="meta-date">{buildDate}</span> pkl. 10.30 WIB</p>
		<div class="price-table-wrap">
			<table class="price-table">
				<caption class="sr-only">Harga bawang merah hari ini berdasarkan grade</caption>
				<thead>
					<tr>
						<th scope="col">Grade</th>
						<th scope="col">Berat</th>
						<th scope="col">Harga</th>
					</tr>
				</thead>
				<tbody>
					{priceRows.map((row) => (
						<tr>
							<td>{row.grade}</td>
							<td>{row.berat}</td>
							<td>{row.harga}</td>
						</tr>
					))}
				</tbody>
			</table>
		</div>
		<section class="price-cta" aria-labelledby="price-cta-title">
			<div class="price-cta__stripe" aria-hidden="true"></div>
			<div class="price-cta__body">
				<p class="price-cta__text">
					ingin membeli bawang merah langsung dari supplier tangan pertama dengan harga grosir?
				</p>
				<div class="price-cta__actions">
					<a class="price-cta__btn price-cta__btn--primary" href="/">
						<span class="price-cta__btn-main">Jual bawang merah grosir</span>
						<svg class="price-cta__btn-arrow" width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
							<path
								d="M5 12h14m0 0l-6-6m6 6l-6 6"
								stroke="currentColor"
								stroke-width="2"
								stroke-linecap="round"
								stroke-linejoin="round"
							/>
						</svg>
					</a>
					<a class="price-cta__btn price-cta__btn--secondary" href={whatsappHref} target="_blank" rel="noopener noreferrer">
						<span class="price-cta__btn-main">Hubungi via WhatsApp</span>
						<svg class="price-cta__btn-arrow" width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
							<path
								d="M5 12h14m0 0l-6-6m6 6l-6 6"
								stroke="currentColor"
								stroke-width="2"
								stroke-linecap="round"
								stroke-linejoin="round"
							/>
						</svg>
					</a>
				</div>
			</div>
		</section>
	</div>
</Layout>

<JsonLd data={priceStructuredData} />

<script>
	function formatIdDate(date) {
		return new Intl.DateTimeFormat('id-ID', {
			timeZone: 'Asia/Jakarta',
			weekday: 'long',
			year: 'numeric',
			month: 'long',
			day: 'numeric',
		}).format(date);
	}
	var el = document.getElementById('page-date');
	if (el) el.textContent = formatIdDate(new Date());
	var metaEl = document.getElementById('meta-date');
	if (metaEl) metaEl.textContent = formatIdDate(new Date());
	document.title = 'Info Harga Bawang Merah 1 kg Hari ini';
</script>

<style>
	.price-page__title {
		margin-bottom: 0.5rem;
	}

	.price-page__date {
		display: block;
		font-size: clamp(1rem, 2.8vw, 1.2rem);
		font-weight: 700;
	}

	.price-page__meta {
		margin-bottom: 2rem;
		font-size: 0.875rem;
		color: var(--color-muted);
	}

	.price-table-wrap {
		margin-bottom: 3rem;
		border-radius: var(--radius);
		border: 1px solid var(--color-border);
		box-shadow: var(--shadow);
		overflow: hidden;
	}

	.price-table {
		width: 100%;
		border-collapse: collapse;
	}

	.price-table th,
	.price-table td {
		padding: 1rem;
		text-align: left;
		border-bottom: 1px solid var(--color-border);
	}

	.price-table th {
		background: var(--color-surface);
		font-weight: 600;
	}

	.price-table td:last-child {
		font-weight: 700;
		color: var(--color-accent);
	}

	.price-cta {
		margin-top: 3rem;
		padding: 2rem;
		border-radius: var(--radius);
		background: var(--color-accent-soft);
		border: 1px solid var(--color-accent);
		text-align: center;
	}

	.price-cta__stripe {
		height: 4px;
		background: var(--color-accent);
		margin-bottom: 1.5rem;
	}

	.price-cta__text {
		margin-bottom: 2rem;
		font-size: 1.125rem;
		font-weight: 500;
	}

	.price-cta__actions {
		display: flex;
		flex-direction: column;
		gap: 1rem;
		align-items: center;
	}

	@media (min-width: 640px) {
		.price-cta__actions {
			flex-direction: row;
			justify-content: center;
		}
	}

	.price-cta__btn {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.75rem 1.5rem;
		border-radius: var(--radius);
		font-weight: 600;
		text-decoration: none;
		transition: all 0.2s ease;
	}

	.price-cta__btn--primary {
		background: var(--color-accent);
		color: white;
	}

	.price-cta__btn--primary:hover {
		background: #9f1239;
		transform: translateY(-1px);
		box-shadow: 0 4px 12px rgba(159, 18, 57, 0.3);
	}

	.price-cta__btn--secondary {
		background: white;
		color: var(--color-accent);
		border: 2px solid var(--color-accent);
	}

	.price-cta__btn--secondary:hover {
		background: var(--color-accent);
		color: white;
		transform: translateY(-1px);
		box-shadow: 0 4px 12px rgba(159, 18, 57, 0.2);
	}

	.price-cta__btn-arrow {
		transition: transform 0.2s ease;
	}

	.price-cta__btn:hover .price-cta__btn-arrow {
		transform: translateX(2px);
	}

	.sr-only {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border: 0;
	}
</style>

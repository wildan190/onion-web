---
import Layout from '../layouts/Layout.astro';
import SocialIconLinks from '../components/SocialIconLinks.astro';
import JsonLd from '../components/JsonLd.astro';
import {
	logoUrl,
	orgId,
	postalAddressBlock,
	sameAsProfiles,
	siteEmail,
	siteOrigin,
	siteTelephoneE164,
	websiteId,
} from '../data/schema-site';

const mapEmbedSrc =
	'https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3959.496536404526!2d110.7514169!3d-7.0682820999999985!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x2e70bdbca3a0462f%3A0xe8743627fec392d1!2smitrabawang.id%20%7C%20Supplier%20%26%20Distributor%20Bawang%20Merah%20Penjualan%20Grosir%20untuk%20Agen!5e0!3m2!1sid!2skr!4v1775140423549!5m2!1sid!2skr';

const warehouseAddress =
	'Manggihan Laban, RT.10/RW.03, Sambung, Kec. Godong, Kabupaten Grobogan, Jawa Tengah 58162, Indonesia.';
const googleMapsPlaceUrl =
	'https://www.google.com/maps/search/?api=1&query=mitrabawang.id+Supplier+Distributor+Bawang+Merah+Godong+Grobogan';
const whatsappHref = 'https://wa.me/6281233624549';
const whatsappDisplay = '0812-3362-4549';
const email = 'mitrabawang.id@gmail.com';

const origin = siteOrigin(Astro.site);
const organizationRef = orgId(origin);
const webSiteRef = websiteId(origin);
const aboutStructuredData = {
	'@context': 'https://schema.org',
	'@graph': [
		{
			'@type': 'Organization',
			'@id': organizationRef,
			name: 'mitrabawang.id',
			url: `${origin}/`,
			logo: { '@type': 'ImageObject', url: logoUrl(origin) },
			email: siteEmail,
			telephone: siteTelephoneE164,
			address: postalAddressBlock(),
			sameAs: [...sameAsProfiles],
		},
		{
			'@type': 'WebSite',
			'@id': webSiteRef,
			url: `${origin}/`,
			name: 'mitrabawang.id',
			inLanguage: 'id-ID',
			publisher: { '@id': organizationRef },
		},
		{
			'@type': 'AboutPage',
			'@id': `${origin}/about/#webpage`,
			url: `${origin}/about/`,
			name: 'Tentang mitrabawang.id',
			description:
				'mitrabawang.id adalah unit usaha perdagangan komoditas bawang merah. Alamat gudang Grobogan, kontak WhatsApp, email, dan media sosial.',
			inLanguage: 'id-ID',
			isPartOf: { '@id': webSiteRef },
			mainEntity: { '@id': organizationRef },
			about: { '@id': organizationRef },
		},
	],
};
---

<Layout
	title="Tentang mitrabawang.id — Hubungi kami"
	description="mitrabawang.id adalah unit usaha perdagangan komoditas bawang merah. Alamat gudang Grobogan, peta Google Maps, WhatsApp, email, dan media sosial."
>
	<div class="about">
		<header class="about-hero" aria-labelledby="about-title">
			<div class="about-hero__stripe" aria-hidden="true"></div>
			<div class="about-hero__bg" aria-hidden="true"></div>
			<div class="about-hero__inner">
				<div class="about-hero__brand">
					<picture>
						<source srcset="/assets/img/emblem-72.webp" type="image/webp">
						<img
							class="about-hero__emblem"
							src="/assets/img/emblem-72.png"
							alt=""
							width="72"
							height="72"
							decoding="async"
						/>
					</picture>
					<div class="about-hero__copy">
						<p class="about-eyebrow">
							<span class="about-pill">mitrabawang.id</span>
							<span class="about-pill about-pill--muted">Grobogan, Jawa Tengah</span>
						</p>
						<h1 id="about-title">Tentang mitrabawang.id</h1>
						<p class="about-hero__intro">
							mitrabawang.id adalah unit usaha perdagangan komoditas bawang merah.
						</p>
					</div>
				</div>
			</div>
		</header>

		<section class="about-contact" aria-labelledby="contact-title">
			<div class="about-wrap">
				<h2 id="contact-title" class="about-contact__title">Hubungi mitrabawang.id</h2>

				<div class="about-grid">
					<div class="about-info">
						<p class="about-kicker">Alamat gudang</p>
						<address class="about-address">{warehouseAddress}</address>

						<aside class="about-info__stack" aria-label="Kontak dan jam operasional">
							<div class="about-card">
								<h3 class="about-card__title">Jam operasional</h3>
								<p class="about-card__text">Senin – Minggu 24 Jam.</p>
							</div>

							<a class="about-tile about-tile--wa" href={whatsappHref} target="_blank" rel="noopener noreferrer">
								<span class="about-tile__label">WhatsApp</span>
								<span class="about-tile__value">{whatsappDisplay}</span>
							</a>

							<a class="about-tile about-tile--mail" href={`mailto:${email}`}>
								<span class="about-tile__label">Email</span>
								<span class="about-tile__value">{email}</span>
							</a>

							<div class="about-card about-card--social">
								<h3 class="about-card__title">Media sosial</h3>
								<div class="about-card__social">
									<SocialIconLinks />
								</div>
							</div>
						</aside>
					</div>

					<div class="about-map-panel">
						<p class="about-kicker about-kicker--map">Lokasi di peta</p>
						<div class="about-map-frame">
							<iframe
								title="Peta lokasi gudang mitrabawang.id di Google Maps"
								src={mapEmbedSrc}
								width="400"
								height="260"
								style="border:0"
								allowfullscreen=""
								loading="lazy"
								referrerpolicy="no-referrer-when-downgrade"></iframe>
						</div>
						<a
							class="about-map-link"
							href={googleMapsPlaceUrl}
							target="_blank"
							rel="noopener noreferrer"
						>
							<span>Buka di Google Maps</span>
							<svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
								<path
									d="M7 17L17 7M17 7H9M17 7V15"
									stroke="currentColor"
									stroke-width="2"
									stroke-linecap="round"
									stroke-linejoin="round"></path>
							</svg>
						</a>
					</div>
				</div>
			</div>
		</section>

		<JsonLd schema={aboutStructuredData} />
	</div>
</Layout>

<style>
	.about {
		--ab-rose: #9f1239;
		--ab-rose-dark: #881337;
		--ab-slate: #1c1917;
		--ab-slate-soft: #44403c;
		--ab-cream: #faf7f2;
		--ab-radius: 16px;
		--ab-radius-lg: 24px;
		width: 100%;
		overflow-x: clip;
	}

	.about-wrap {
		width: 100%;
		max-width: var(--max-width);
		margin: 0 auto;
		padding: 0 1.25rem;
		box-sizing: border-box;
	}

	/* Hero */
	.about-hero {
		position: relative;
		padding: 0 0 clamp(1.75rem, 5vw, 2.75rem);
	}

	.about-hero__stripe {
		height: 4px;
		width: 100%;
		background: linear-gradient(90deg, #9f1239 0%, #c2410c 50%, #ea580c 100%);
	}

	.about-hero__bg {
		position: absolute;
		inset: 4px 0 0;
		background:
			radial-gradient(ellipse 75% 55% at 100% 0%, rgba(159, 18, 57, 0.11), transparent 55%),
			radial-gradient(ellipse 65% 45% at 0% 100%, rgba(217, 119, 6, 0.09), transparent 50%),
			linear-gradient(180deg, #fff 0%, var(--ab-cream) 100%);
		pointer-events: none;
	}

	.about-hero__inner {
		position: relative;
		max-width: var(--max-width);
		margin: 0 auto;
		padding: clamp(1.5rem, 4vw, 2.5rem) 1.25rem 0;
	}

	.about-hero__brand {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 1.25rem;
	}

	@media (min-width: 640px) {
		.about-hero__brand {
			flex-direction: row;
			align-items: center;
			gap: 1.5rem;
		}
	}

	.about-hero__emblem {
		flex-shrink: 0;
		border-radius: 18px;
		border: 1px solid rgba(28, 25, 23, 0.08);
		box-shadow: 0 12px 40px rgba(28, 25, 23, 0.08);
		background: #fff;
	}

	.about-eyebrow {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		margin: 0 0 0.85rem;
	}

	.about-pill {
		display: inline-flex;
		align-items: center;
		padding: 0.35rem 0.85rem;
		font-size: 0.78rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		border-radius: 999px;
		background: rgba(159, 18, 57, 0.1);
		color: var(--ab-rose);
		border: 1px solid rgba(159, 18, 57, 0.2);
	}

	.about-pill--muted {
		background: rgba(68, 64, 60, 0.08);
		color: var(--ab-slate-soft);
		border-color: rgba(68, 64, 60, 0.12);
	}

	.about h1 {
		font-size: clamp(1.85rem, 4.5vw, 2.5rem);
		font-weight: 800;
		line-height: 1.15;
		letter-spacing: -0.035em;
		margin: 0 0 0.75rem;
		color: var(--ab-slate);
	}

	.about-hero__intro {
		margin: 0;
		font-size: clamp(1.05rem, 2.2vw, 1.2rem);
		line-height: 1.6;
		color: var(--ab-slate-soft);
		max-width: 38rem;
	}

	/* Contact + map */
	.about-contact {
		padding: clamp(1.5rem, 4vw, 2.5rem) 0 clamp(2.5rem, 6vw, 4rem);
		background: var(--ab-cream);
	}

	.about-contact__title {
		font-size: clamp(1.4rem, 3.2vw, 1.85rem);
		font-weight: 800;
		line-height: 1.2;
		letter-spacing: -0.03em;
		margin: 0 0 1.35rem;
		color: var(--ab-slate);
		text-align: center;
	}

	.about-grid {
		display: grid;
		gap: 1.5rem;
		align-items: start;
	}

	@media (min-width: 900px) {
		.about-grid {
			grid-template-columns: minmax(0, 1fr) minmax(240px, 320px);
			gap: 1.75rem;
			align-items: start;
		}
	}

	.about-info {
		background: #fff;
		border: 1px solid var(--color-border);
		border-radius: var(--ab-radius-lg);
		padding: clamp(1.25rem, 3vw, 1.75rem);
		box-shadow: 0 4px 28px rgba(28, 25, 23, 0.06);
	}

	.about-info__stack {
		display: flex;
		flex-direction: column;
		gap: 1rem;
		margin-top: 0.25rem;
	}

	.about-kicker {
		margin: 0 0 0.5rem;
		font-size: 0.72rem;
		font-weight: 800;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: #78716c;
	}

	.about-address {
		margin: 0 0 1rem;
		font-style: normal;
		font-size: 1.02rem;
		line-height: 1.65;
		color: var(--ab-slate-soft);
	}

	.about-kicker--map {
		margin-bottom: 0.45rem;
	}

	.about-map-panel {
		background: #fff;
		border: 1px solid var(--color-border);
		border-radius: var(--ab-radius-lg);
		padding: clamp(1rem, 2.5vw, 1.35rem);
		box-shadow: 0 4px 24px rgba(28, 25, 23, 0.06);
	}

	@media (min-width: 900px) {
		.about-map-panel {
			position: sticky;
			top: 1rem;
		}
	}

	.about-map-frame {
		border-radius: var(--ab-radius);
		overflow: hidden;
		border: 1px solid var(--color-border);
		box-shadow: 0 8px 24px rgba(28, 25, 23, 0.08);
		line-height: 0;
	}

	.about-map-frame iframe {
		width: 100%;
		height: min(220px, 42vh);
		display: block;
	}

	@media (min-width: 900px) {
		.about-map-frame iframe {
			height: 200px;
		}
	}

	.about-map-link {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.45rem;
		margin-top: 0.75rem;
		width: 100%;
		padding: 0.65rem 1.15rem;
		font-weight: 700;
		font-size: 0.95rem;
		color: var(--ab-rose);
		text-decoration: none;
		border: 2px solid rgba(159, 18, 57, 0.25);
		border-radius: 12px;
		background: #fff;
		transition:
			border-color 0.15s ease,
			background 0.15s ease,
			color 0.15s ease;
	}

	.about-map-link:hover {
		border-color: var(--ab-rose);
		background: #fff5f7;
		color: var(--ab-rose-dark);
	}

	.about-card {
		background: #fff;
		border: 1px solid var(--color-border);
		border-radius: var(--ab-radius);
		padding: 1.15rem 1.25rem;
		box-shadow: 0 2px 14px rgba(28, 25, 23, 0.04);
	}

	.about-card--social {
		padding-bottom: 1.35rem;
	}

	.about-card__title {
		margin: 0 0 0.5rem;
		font-size: 0.75rem;
		font-weight: 800;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: #78716c;
	}

	.about-card__text {
		margin: 0;
		font-size: 1.08rem;
		font-weight: 700;
		color: var(--ab-slate);
		line-height: 1.45;
	}

	.about-card__social :global(.sil) {
		justify-content: flex-start;
		margin-top: 0.35rem;
	}

	.about-tile {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 0.2rem;
		padding: 1rem 1.15rem;
		border-radius: var(--ab-radius);
		text-decoration: none;
		font-weight: 800;
		border: 2px solid transparent;
		transition:
			background 0.15s ease,
			border-color 0.15s ease,
			transform 0.15s ease;
	}

	.about-tile:active {
		transform: scale(0.99);
	}

	.about-tile__label {
		font-size: 0.68rem;
		font-weight: 800;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		opacity: 0.92;
	}

	.about-tile__value {
		font-size: 1.02rem;
		word-break: break-word;
		line-height: 1.35;
	}

	.about-tile--wa {
		background: #25d366;
		color: #fff;
		box-shadow: 0 6px 20px rgba(37, 211, 102, 0.32);
	}

	.about-tile--wa:hover {
		background: #1fb855;
		color: #fff;
	}

	.about-tile--wa .about-tile__label {
		color: rgba(255, 255, 255, 0.92);
	}

	.about-tile--mail {
		background: linear-gradient(180deg, #fafaf9 0%, #fff 100%);
		border-color: var(--color-border);
		color: var(--ab-slate);
	}

	.about-tile--mail:hover {
		border-color: var(--ab-rose);
		color: var(--ab-rose);
	}

	@media (prefers-reduced-motion: reduce) {
		.about-tile:active {
			transform: none;
		}
	}
</style>

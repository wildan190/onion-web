---
import Layout from '../layouts/Layout.astro';
import SocialIconLinks from '../components/SocialIconLinks.astro';
import JsonLd from '../components/JsonLd.astro';
import {
	logoUrl,
	orgId,
	postalAddressBlock,
	sameAsProfiles,
	siteEmail,
	siteOrigin,
	siteTelephoneE164,
} from '../data/schema-site';

const mapEmbedSrc =
	'https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3959.496536404526!2d110.7514169!3d-7.0682820999999985!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x2e70bdbca3a0462f%3A0xe8743627fec392d1!2smitrabawang.id%20%7C%20Supplier%20%26%20Distributor%20Bawang%20Merah%20Penjualan%20Grosir%20untuk%20Agen!5e0!3m2!1sid!2skr!4v1775140423549!5m2!1sid!2skr';

const warehouseAddress =
	'Manggihan Laban, RT.10/RW.03, Sambung, Kec. Godong, Kabupaten Grobogan, Jawa Tengah 58162, Indonesia.';

const whatsappNumber = '6281233624549';
const whatsappDisplay = '0812-3362-4549';
const whatsappHref = `https://wa.me/${whatsappNumber}`;

const qualityChecks = [
	'Tidak mudah busuk',
	'Daya simpan hingga ±6 bulan',
	'Dapat dijadikan bibit',
];

const productTypes = [
	{ title: 'Bawang Merah Ikat', sub: 'Masih berdaun', variant: 'ikat' as const, image: '/assets/img/home/img6.jpeg' },
	{ title: 'Bawang Merah Bersih', sub: 'Tanpa daun', variant: 'bersih' as const, image: '/assets/img/home/img7.jpeg' },
];

const distribution: { region: string; markets: string[] }[] = [
	{
		region: 'DKI Jakarta & Banten',
		markets: [
			'Pasar Induk Kramat Jati (Jakarta Timur)',
			'Pasar Induk Tanah Tinggi (Tangerang)',
			'Pasar Induk Rau (Serang)',
			'Pasar Kebayoran Lama (Jakarta Selatan)',
		],
	},
	{
		region: 'Jawa Barat',
		markets: [
			'Pasar Induk Caringin (Bandung)',
			'Pasar Induk Cibitung (Bekasi)',
			'Pasar Induk Kemang / Teknik Umum (Bogor)',
			'Pasar Induk Cikopo (Purwakarta)',
			'Pasar Induk Jagasatru (Cirebon)',
			'Pasar Gede (Bageut / Sukabumi)',
		],
	},
	{
		region: 'Jawa Tengah',
		markets: [
			'Pasar Induk Legi (Solo)',
			'Pasar Johar (Semarang)',
			'Pasar Sayur Cepogo (Boyolali)',
			'Pasar Bandungan (Semarang)',
			'Pasar Induk Pemalang',
			'Pasar Sayur Kutabawa (Purbalingga)',
			'Pasar Bawang Sengon (Brebes)',
			'Pasar Sayur Jetis (Bandungan)',
		],
	},
	{
		region: 'DI Yogyakarta',
		markets: [
			'Pasar Induk Giwangan (Yogyakarta)',
			'Pasar Gamping (Sleman)',
			'Pasar Beringharjo (Yogyakarta)',
		],
	},
	{
		region: 'Jawa Timur',
		markets: [
			'Pasar Induk Osowilangun (Surabaya)',
			'Pasar Induk Gadang (Malang)',
			'Pasar Sayur Pare (Kediri)',
			'Pasar Induk Puspa Agro (Sidoarjo)',
			'Pasar Induk Keputran (Surabaya)',
			'Pasar Sayur Magetan',
			'Pasar Bawang Merah Sukomoro (Nganjuk)',
			'Pasar Bawang Dringu (Probolinggo)',
		],
	},
];

const googleMapsPlaceUrl =
	'https://www.google.com/maps/search/?api=1&query=mitrabawang.id+Supplier+Distributor+Bawang+Merah+Godong+Grobogan';

/** Hero: img1–2 potret. Cerita: img3–5 landscape. Kualitas: img6–8 potret. Semua `.jpeg`. */
const homeImgHero = {
	primary: '/assets/img/home/img1.jpeg',
	secondary: '/assets/img/home/img2.jpeg',
} as const;
const homeStoryPhotos = [
	{ src: '/assets/img/home/img3.jpeg', alt: 'Aktivitas dan lingkungan usaha bawang merah mitrabawang.id' },
	{ src: '/assets/img/home/img4.jpeg', alt: 'Kegiatan mitrabawang.id bersama petani dan gudang' },
	{ src: '/assets/img/home/img5.jpeg', alt: 'Perjalanan produk bawang merah mitrabawang.id' },
] as const;
const homeQualityPhotos = [
	{ src: '/assets/img/home/img6.jpeg', alt: 'Bawang merah berkualitas — sortir mitrabawang.id' },
	{ src: '/assets/img/home/img7.jpeg', alt: 'Produk bawang merah ikat dan bersih mitrabawang.id' },
	{ src: '/assets/img/home/img8.jpeg', alt: 'Bawang merah siap edar dari gudang mitrabawang.id' },
] as const;

const origin = siteOrigin(Astro.site);
const organizationRef = orgId(origin);
const homeStructuredData = {
	'@context': 'https://schema.org',
	'@graph': [
		{
			'@type': 'Organization',
			'@id': organizationRef,
			name: 'mitrabawang.id',
			alternateName: 'Supplier & Distributor Bawang Merah mitrabawang.id',
			url: `${origin}/`,
			logo: { '@type': 'ImageObject', url: logoUrl(origin) },
			image: logoUrl(origin),
			description:
				'Supplier bawang merah tangan pertama setelah petani. Harga grosir, distribusi ke seluruh Indonesia dan ekspor. Gudang Grobogan, Jawa Tengah.',
			email: siteEmail,
			telephone: siteTelephoneE164,
			address: postalAddressBlock(),
			contactPoint: [
				{
					'@type': 'ContactPoint',
					telephone: siteTelephoneE164,
					contactType: 'sales',
					availableLanguage: ['Indonesian', 'id'],
					areaServed: 'ID',
				},
			],
			sameAs: [...sameAsProfiles],
		},
		{
			'@type': 'Product',
			'@id': `${origin}/#product-bawang-merah`,
			name: 'Bawang Merah Grosir (mitrabawang.id)',
			description:
				'Bawang merah segar: varian ikat (berdaun) dan bersih untuk agen, distributor, dan grosir. Supply tangan pertama setelah petani.',
			sku: 'BM-GROSIR',
			brand: { '@id': organizationRef },
			category: 'Fresh produce — red onion / shallot wholesale',
			image: logoUrl(origin),
			offers: {
				'@type': 'AggregateOffer',
				priceCurrency: 'IDR',
				lowPrice: '22000',
				highPrice: '35000',
				offerCount: 3,
				availability: 'https://schema.org/InStock',
				url: `${origin}/harga-bawang-merah-hari-ini/`,
				seller: { '@id': organizationRef },
			},
		},
	],
};
---

<Layout
	title="mitrabawang.id — Supplier & Distributor Bawang Merah Grosir untuk Agen"
	description="Supplier bawang merah tangan pertama setelah petani. Harga grosir, distribusi ke seluruh Indonesia dan ekspor. Gudang Grobogan, Jawa Tengah."
>
	<div class="home">
		<!-- Hero -->
		<section class="home-hero" aria-labelledby="home-hero-title">
			<div class="home-hero__bg" aria-hidden="true"></div>
			<div class="home-hero__inner">
				<div class="home-hero__copy">
					<h2 id="home-hero-title" class="home-hero__title">
						Supplier &amp; Distributor Bawang Merah <span class="home-hero__accent">Penjualan Grosir</span>
					</h2>
					<p class="home-hero__text">
						<strong>mitrabawang.id</strong> adalah supplier bawang merah tangan pertama setelah petani. Kami menjual
						bawang merah dengan harga grosir, melayani distribusi ke seluruh Indonesia bahkan hingga ekspor.
					</p>
					<p class="home-hero__text" style="margin-top: -0.5rem;">
						<span class="home-stat__num">mitrabawang.id lahir dari keprihatinan kami terhadap kondisi petani bawang merah yang kerap menghadapi anjloknya harga di tingkat petani.</span>
					</p>
					<p class="home-hero__text" style="margin-top: -0.5rem;">
						Kami menginisiasi mitrabawang.id sebagai wadah kolaboratif bagi para petani bawang merah, agar petani
						dapat menjual hasil panennya dengan harga yang lebih adil, transparan, dan menguntungkan. Kami percaya,
						kesejahteraan petani adalah fondasi utama dari kualitas bawang merah sampai ke tangan konsumen.
					</p>
					<p class="home-hero__text" style="margin-top: -0.5rem;">
						Tidak hanya berperan sebagai penghubung pasar, kami juga secara aktif melakukan pelatihan, penyuluhan, dan
						pendampingan bersama petani. Langkah ini kami lakukan untuk memastikan setiap petani mampu menghasilkan bawang merah berkualitas
						tinggi, sekaligus menjaga ketersediaan stok yang stabil dan berkelanjutan.
					</p>
					<p class="home-hero__text" style="margin-top: -0.5rem;">
						Dengan pendekatan ini, mitrabawang.id tidak hanya menjadi supplier atau distributor, tetapi juga menjadi
						<strong>mitra strategis petani dan agen pengecer bawang merah</strong>.
					</p>
					<div class="home-hero__actions">
						<a class="home-btn home-btn--primary" href={whatsappHref} target="_blank" rel="noopener noreferrer">
							Chat WhatsApp
						</a>
						<a class="home-btn home-btn--outline" href="/harga-bawang-merah-hari-ini">Harga hari ini</a>
					</div>
				</div>
				<div class="home-hero__right">
					<div class="home-hero__visuals home-hero__visuals--single">
						<figure class="home-hero__figure home-hero__figure--a">
							<img
								src="/assets/img/home/img8.jpeg"
								alt="Bawang merah dan aktivitas mitrabawang.id"
								width="720"
								height="960"
								loading="eager"
								decoding="async"
							/>
						</figure>
					</div>
				</div>
			</div>
			<div class="home-hero__bar">
				<div class="home-wrap">
					<aside class="home-hero__panel" aria-label="Ringkasan">
						<div class="home-stat">
							<span class="home-stat__num">24/7</span>
							<span class="home-stat__label">Jam operasional gudang</span>
						</div>
						<div class="home-stat">
							<span class="home-stat__num">Bima &amp; Brebes</span>
							<span class="home-stat__label">Varietas unggulan mitra petani</span>
						</div>
						<div class="home-stat">
							<span class="home-stat__num">±6 bln</span>
							<span class="home-stat__label">Daya simpan (askip kering)</span>
						</div>
						<a class="home-hero__panel-link" href="/exporter-red-onion-shallot-from-indonesia">
							Ekspor red onion →
						</a>
					</aside>
				</div>
			</div>
		</section>
		<section class="home-section home-section--quality" id="kualitas" aria-labelledby="quality-heading">
			<div class="home-quality-skin" aria-hidden="true"></div>
			<div class="home-wrap home-quality-wrap">
				<header class="home-quality-head">
					<p class="home-quality-ribbon">Askip tua &amp; kering · Sortir ketat</p>
					<h2 id="quality-heading" class="home-h2 home-quality-title">Jual Bawang Merah Berkualitas</h2>
					<p class="home-quality-head__sub">
						Bersama petani mitra, kami secara konsisten mengembangkan varietas unggulan seperti
						<strong>Bima</strong> dan <strong>Brebes</strong> yang sudah terbukti memiliki permintaan banyak di pasaran.
					</p>
					<div class="home-quality-varieties" aria-hidden="true">
						<span class="home-quality-varieties__pill">Bima</span>
						<span class="home-quality-varieties__pill">Brebes</span>
					</div>
				</header>
				<div class="home-quality-grid">
					<div class="home-quality-main">
						<p class="home-quality-kicker">Kami tidak asal jual</p>
						<p class="home-quality-lead">
							Kami hanya menjual bawang merah tua dan kering (askip) yang sudah melalui proses sortir yang ketat,
							sehingga:
						</p>
						<ul class="home-checklist">
							{qualityChecks.map((t) => (
								<li>
									<span class="home-checklist__icon" aria-hidden="true">✓</span>
									{t}
								</li>
							))}
						</ul>
					</div>
					<div class="home-quality-products">
						<p class="home-quality-kicker">Dua jenis untuk kebutuhan pasar</p>
						<div class="home-product-cards">
							{
								productTypes.map(({ title, sub, variant, image }) => (
									<div class:list={['home-product-card', `home-product-card--${variant}`]}>
										<img src={image} alt={title} width="720" height="960" loading="lazy" decoding="async" class="home-product-card__img" />
										<span class="home-product-card__n">{title}</span>
										<span class="home-product-card__sub">{sub}</span>
									</div>
								))
							}
						</div>
						<div class="home-price-band">
							<span class="home-price-band__label">Kisaran harga</span>
							<span class="home-price-band__value">Rp 22.000 – Rp 35.000 / KG</span>
							<span class="home-price-band__hint">(dapat berubah mengikuti pasar)</span>
						</div>
						<a class="home-quality-price-link" href="/harga-bawang-merah-hari-ini">
							<span>Harga Bawang Merah Hari ini</span>
						</a>
					</div>
				</div>
			</div>
		</section>
		<section class="home-section" aria-labelledby="warehouse-heading">
			<div class="home-wrap">
				<div class="home-map-layout">
					<div class="home-map-copy">
						<h2 id="warehouse-heading" class="home-h2">Lokasi Gudang Bawang Merah mitrabawang.id</h2>
						<address class="home-address">
							{warehouseAddress}
						</address>
						<div class="home-map-frame" style="margin-top: 1.25rem;">
							<iframe
								title="Peta lokasi gudang mitrabawang.id di Google Maps"
								src={mapEmbedSrc}
								width="600"
								height="350"
								style="border:0"
								allowfullscreen=""
								loading="lazy"
								referrerpolicy="no-referrer-when-downgrade"></iframe>
						</div>
					</div>
					<div class="home-map-image">
						<img src="/assets/img/home/img2.jpeg" alt="Gudang mitrabawang.id" loading="lazy" decoding="async" style="width: 100%; height: auto; object-fit: cover; border-radius: var(--home-radius-lg); border: 1px solid rgba(28, 25, 23, 0.08); box-shadow: 0 16px 48px rgba(28, 25, 23, 0.1);" />
					</div>
				</div>
			</div>
		</section>
		<section class="home-section home-section--markets" aria-labelledby="markets-heading">
			<div class="home-wrap">
				<p class="home-markets-lead">
					mitrabawang.id memiliki jaringan distribusi yang terintegrasi, sehingga meminimalisir risiko kebusukan selama pengiriman.
				</p>
				<div class="home-region-grid">
					{
						distribution.map(({ region, markets }, i) => (
							<article class:list={['home-region-card', i % 2 === 1 && 'home-region-card--alt']}>
								<h3 class="home-h3">{region}</h3>
								<ul class="home-region-list">
									{markets.map((m) => (
										<li>{m}</li>
									))}
								</ul>
							</article>
						))
					}
				</div>
				<div class="home-export">
					<div class="home-export__visual" aria-hidden="true">
						<div class="home-export__onion">
							<span class="home-export__onion-ring home-export__onion-ring--1"></span>
							<span class="home-export__onion-ring home-export__onion-ring--2"></span>
							<span class="home-export__onion-ring home-export__onion-ring--3"></span>
							<span class="home-export__onion-ring home-export__onion-ring--4"></span>
							<span class="home-export__onion-ring home-export__onion-ring--5"></span>
							<span class="home-export__onion-core"></span>
						</div>
						<p class="home-export__visual-caption">Shallot · Red onion</p>
					</div>
					<div class="home-export__main">
						<p class="home-export__eyebrow">Ekspor bawang merah</p>
						<p class="home-export__text">
							Selain melayani pengiriman ke seluruh Indonesia, kami juga mengekspor bawang merah ke negara tetangga
							Asia Tenggara.
						</p>
						<ul class="home-export__countries" role="list">
							<li>Singapore</li>
							<li>Malaysia</li>
							<li>Thailand</li>
							<li>Vietnam</li>
						</ul>
						<a class="home-export__cta" href="/exporter-red-onion-shallot-from-indonesia">
							<span>Exporter Red Onion (Shallot) From Indonesia</span>
							<svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
								<path
									d="M5 12h14m0 0l-6-6m6 6l-6 6"
									stroke="currentColor"
									stroke-width="2"
									stroke-linecap="round"
									stroke-linejoin="round"></path>
							</svg>
						</a>
					</div>
				</div>
			</div>
		</section>
		<section class="home-section home-section--social-proof" aria-labelledby="testimoni-heading">
			<div class="home-wrap">
				<h2 id="testimoni-heading" class="home-h2">Testimoni</h2>
				<p class="home-social-lead">
					Lihat ulasan dan reputasi kami di Google Maps, serta aktivitas perdagangan bawang merah di kanal video &
					sosial.
				</p>
				<div class="home-proof-grid">
					<div class="home-proof-card home-proof-card--map">
						<h3 class="home-h3">Ulasan di Google Maps</h3>
						<p class="home-proof-card__text">
							Tinjau lokasi bisnis dan ulasan pelanggan di peta resmi mitrabawang.id.
						</p>
						<div class="home-proof-embed">
							<iframe
								title="Google Maps — mitrabawang.id (ulasan & lokasi)"
								src={mapEmbedSrc}
								width="600"
								height="320"
								style="border:0"
								allowfullscreen=""
								loading="lazy"
								referrerpolicy="no-referrer-when-downgrade"></iframe>
						</div>
						<a class="home-btn home-btn--outline home-btn--full" href="https://maps.app.goo.gl/jxH1LBs7EkQmD9WT9" target="_blank" rel="noopener noreferrer">
							Buka di Google Maps
						</a>
					</div>
					<div class="home-proof-card home-proof-card--social-icons">
						<h3 class="home-h3">Aktivitas di media sosial</h3>
						<p class="home-proof-card__text">Lihat aktivitas perdagangan bawang merah kami.</p>
						<div class="home-proof-social-row">
							<SocialIconLinks />
						</div>
					</div>
				</div>
				<div class="home-story">
					<p class="home-story__photos-caption">
						Cuplikan aktivitas, lingkungan gudang, dan perjalanan produk kami.
					</p>
					<div
						class="home-story__photos"
						role="region"
						aria-roledescription="carousel"
						aria-label="Foto aktivitas dan lingkungan — geser untuk melihat lainnya"
					>
						{
							homeStoryPhotos.map(({ src, alt }) => (
								<figure class="home-story__photo">
									<img src={src} alt={alt} width="1200" height="750" loading="lazy" decoding="async" />
								</figure>
							))
						}
					</div>
				</div>
			</div>
		</section>
		<section class="home-section home-section--cta-agent" aria-labelledby="agent-heading">
			<div class="home-wrap home-cta-agent">
				<div class="home-cta-agent__decor" aria-hidden="true"></div>
				<h2 id="agent-heading" class="home-h2 home-h2--on-dark">
					Anda Agen Bawang Merah? Ingin Membeli dengan Harga Grosir?
				</h2>
				<p class="home-cta-agent__text">
					mitrabawang.id mengedepankan transparansi harga dan timbangan dengan prinsip kepercayaan serta kejujuran. Jika
					Anda ingin membeli dengan kuantitas banyak, kami sarankan untuk datang langsung ke gudang mitrabawang.id.
					Hubungi kami terlebih dahulu melalui WhatsApp.
				</p>
				<a class="home-btn home-btn--whatsapp" href={whatsappHref} target="_blank" rel="noopener noreferrer">
					Hubungi via WhatsApp
				</a>
			</div>
		</section>
		<section class="home-section home-section--contact" aria-labelledby="contact-heading" id="kontak">
			<div class="home-wrap">
				<h2 id="contact-heading" class="home-h2 home-contact-page-title">Hubungi mitrabawang.id</h2>
				<div class="home-contact-shell">
					<div class="home-contact-grid">
						<div class="home-contact-block home-contact-block--location">
							<p class="home-contact-kicker">Lokasi gudang</p>
							<address class="home-contact-address">{warehouseAddress}</address>
							<dl class="home-contact-hours">
								<div class="home-contact-hours__row">
									<dt>Jam operasional</dt>
									<dd>Senin – Minggu · 24 jam</dd>
								</div>
							</dl>
							<p class="home-contact-kicker" style="margin-top: 1.5rem;">Hubungi cepat</p>
							<div class="home-contact-channels-inline">
								<a class="home-contact-btn home-contact-btn--wa" href={whatsappHref} target="_blank" rel="noopener noreferrer">
									<span class="home-contact-btn__label">WhatsApp</span>
									<span class="home-contact-btn__value">{whatsappDisplay}</span>
								</a>
								<a class="home-contact-btn home-contact-btn--mail" href="mailto:mitrabawang.id@gmail.com">
									<span class="home-contact-btn__label">Email</span>
									<span class="home-contact-btn__value">mitrabawang.id@gmail.com</span>
								</a>
							</div>
						</div>
						<div class="home-contact-block home-contact-block--channels">
							<p class="home-contact-kicker">Form Order</p>
							<form class="home-order-form" onsubmit="event.preventDefault(); const fd = new FormData(this); const t = `Halo mitrabawang.id, saya ingin melakukan pemesanan.\n\n*Nama Lengkap*: ${fd.get('nama')}\n*Jumlah Order*: ${fd.get('jumlah')}\n*Alamat Pengiriman*: ${fd.get('alamat')}`; window.open(`https://wa.me/6281233624549?text=${encodeURIComponent(t)}`, '_blank');">
								<div class="form-group">
									<label for="order-nama">Nama Lengkap</label>
									<input type="text" id="order-nama" name="nama" required placeholder="Siapa nama Anda?" />

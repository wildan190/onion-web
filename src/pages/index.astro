		background: linear-gradient(145deg, #15803d 0%, #22c55e 100%);
		box-shadow: 0 2px 8px rgba(21, 128, 61, 0.35);
		margin-top: 0.12rem;
	}

	.home-product-cards {
		display: grid;
		gap: 0.85rem;
		margin-bottom: 1.25rem;
	}

	.home-product-card {
		border-radius: 14px;
		padding: 1.05rem 1.2rem;
		display: flex;
		flex-direction: column;
		gap: 0.35rem;
		position: relative;
		overflow: hidden;
	}

	.home-product-card--ikat {
		background: linear-gradient(135deg, #f0fdf4 0%, #ecfdf5 50%, #fff 100%);
		border: 1px solid rgba(22, 101, 52, 0.2);
		box-shadow: 0 2px 12px rgba(22, 101, 52, 0.06);
	}

	.home-product-card--ikat::before {
		content: '';
		position: absolute;
		left: 0;
		top: 0;
		bottom: 0;
		width: 4px;
		background: linear-gradient(180deg, #166534, #22c55e);
		border-radius: 4px 0 0 4px;
	}

	.home-product-card--bersih {
		background: linear-gradient(135deg, #fff5f5 0%, #fff1f2 45%, #fff 100%);
		border: 1px solid rgba(159, 18, 57, 0.2);
		box-shadow: 0 2px 12px rgba(159, 18, 57, 0.06);
	}

	.home-product-card--bersih::before {
		content: '';
		position: absolute;
		left: 0;
		top: 0;
		bottom: 0;
		width: 4px;
		background: linear-gradient(180deg, #7f1d1d, #be123c);
		border-radius: 4px 0 0 4px;
	}

	.home-product-card__img {
		width: 100%;
		height: auto;
		border-radius: calc(14px - 0.5rem);
		margin-bottom: 0.5rem;
		aspect-ratio: 1 / 1;
		object-fit: cover;
		display: block;
	}

	.home-product-card__n {
		font-weight: 800;
		color: #1c1917;
		font-size: 1.02rem;
		padding-left: 0.35rem;
	}

	.home-product-card--ikat .home-product-card__n {
		color: #14532d;
	}

	.home-product-card--bersih .home-product-card__n {
		color: #881337;
	}

	.home-product-card__sub {
		font-size: 0.88rem;
		color: #57534e;
		padding-left: 0.35rem;
	}

	.home-price-band {
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
		padding: 1.05rem 1.15rem;
		background: linear-gradient(135deg, #fffbeb 0%, #fef3c7 50%, #fde68a 100%);
		border: 1px solid rgba(202, 138, 4, 0.35);
		border-radius: 14px;
		margin-bottom: 1rem;
		box-shadow: 0 2px 12px rgba(202, 138, 4, 0.12);
	}

	.home-price-band__label {
		font-size: 0.7rem;
		font-weight: 800;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: #92400e;
	}

	.home-price-band__value {
		font-size: 1.35rem;
		font-weight: 800;
		color: #7c2d12;
		letter-spacing: -0.02em;
	}

	.home-price-band__hint {
		font-size: 0.8rem;
		color: #78716c;
	}

	.home-quality-price-link {
		display: inline-flex;
		flex-direction: column;
		gap: 0.15rem;
		padding: 0.75rem 1.1rem;
		border-radius: 12px;
		text-decoration: none;
		background: linear-gradient(135deg, #9f1239 0%, #be123c 100%);
		color: #fff !important;
		font-weight: 800;
		font-size: 0.95rem;
		box-shadow: 0 4px 16px rgba(159, 18, 57, 0.3);
		border: 1px solid rgba(255, 255, 255, 0.15);
		transition:
			transform 0.15s ease,
			box-shadow 0.15s ease;
	}

	.home-quality-price-link:hover {
		color: #fff !important;
		transform: translateY(-2px);
		box-shadow: 0 6px 22px rgba(159, 18, 57, 0.38);
	}

	.home-quality-price-link__sub {
		font-size: 0.72rem;
		font-weight: 600;
		opacity: 0.92;
	}

	@media (prefers-reduced-motion: reduce) {
		.home-quality-price-link:hover {
			transform: none;
		}
	}

	/* Map */
	.home-map-layout {
		display: grid;
		gap: 1.75rem;
		align-items: start;
	}

	@media (min-width: 900px) {
		.home-map-layout {
			grid-template-columns: 1.3fr 0.7fr;
			gap: 2.5rem;
			align-items: center; /* Membuat gambar berada di tengah secara vertikal jika lebih pendek dari panel kiri */
		}
	}

	.home-address {
		font-style: normal;
		font-size: 1.02rem;
		line-height: 1.6;
		color: #44403c;
		margin: 0 0 1rem;
	}

	.home-map-note {
		margin: 0;
		color: #57534e;
		line-height: 1.65;
		font-size: 0.98rem;
	}

	.home-map-frame {
		border-radius: var(--home-radius-lg);
		overflow: hidden;
		border: 1px solid var(--color-border);
		box-shadow: 0 16px 48px rgba(28, 25, 23, 0.1);
		line-height: 0;
	}

	.home-map-frame iframe {
		width: 100%;
		height: min(420px, 55vh);
		display: block;
	}

	/* Markets */
	.home-section--markets {
		background: var(--home-cream);
	}

	.home-markets-lead {
		margin: 0 0 1.5rem;
		max-width: 40rem;
		color: #57534e;
		font-size: 1.02rem;
	}

	.home-region-grid {
		display: grid;
		gap: 1rem;
	}

	@media (min-width: 640px) {
		.home-region-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (min-width: 1100px) {
		.home-region-grid {
			display: flex;
			flex-wrap: wrap;
			justify-content: center;
		}
		.home-region-grid > .home-region-card {
			width: calc(33.333% - 0.67rem);
			flex-shrink: 0;
		}
	}

	.home-region-card {
		background: #fff;
		border-radius: var(--home-radius);
		padding: 1.25rem 1.35rem;
		border: 1px solid var(--color-border);
		box-shadow: 0 2px 12px rgba(28, 25, 23, 0.04);
		transition:
			box-shadow 0.2s ease,
			transform 0.2s ease;
	}

	.home-region-card:hover {
		box-shadow: 0 8px 28px rgba(28, 25, 23, 0.08);
		transform: translateY(-2px);
	}

	.home-region-card--alt {
		background: linear-gradient(180deg, #fff 0%, #fff7ed 100%);
		border-color: rgba(217, 119, 6, 0.15);
	}

	.home-region-card .home-h3 {
		color: var(--home-rose);
		font-size: 0.95rem;
		margin-bottom: 0.75rem;
		padding-bottom: 0.5rem;
		border-bottom: 2px solid rgba(159, 18, 57, 0.15);
	}

	.home-region-list {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 0.45rem;
	}

	.home-region-list li {
		margin: 0;
		font-size: 0.88rem;
		line-height: 1.45;
		color: #57534e;
		padding-left: 0.85rem;
		position: relative;
	}

	.home-region-list li::before {
		content: '';
		position: absolute;
		left: 0;
		top: 0.55em;
		width: 4px;
		height: 4px;
		border-radius: 50%;
		background: var(--home-amber);
	}

	/* Blok ekspor — nuansa kulit & irisan bawang merah */
	.home-export {
		margin-top: 2.5rem;
		display: grid;
		gap: 1.75rem;
		align-items: center;
		padding: clamp(1.5rem, 4vw, 2.25rem) clamp(1.35rem, 4vw, 2.25rem);
		border-radius: var(--home-radius-lg);
		border: 1px solid rgba(190, 18, 60, 0.2);
		background:
			radial-gradient(ellipse 120% 80% at 100% 0%, rgba(254, 205, 211, 0.45) 0%, transparent 55%),
			radial-gradient(ellipse 80% 60% at 0% 100%, rgba(254, 243, 199, 0.35) 0%, transparent 50%),
			linear-gradient(165deg, #fff5f5 0%, #fff1f2 35%, #fdf4f8 70%, #fefce8 100%);
		box-shadow:
			0 1px 0 rgba(255, 255, 255, 0.8) inset,
			0 12px 40px rgba(127, 29, 29, 0.08);
	}

	@media (min-width: 768px) {
		.home-export {
			grid-template-columns: minmax(0, 220px) minmax(0, 1fr);
			gap: 2rem 2.5rem;
		}
	}

	.home-export__visual {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		gap: 0.75rem;
	}

	.home-export__onion {
		position: relative;
		width: min(11rem, 72vw);
		aspect-ratio: 1;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.home-export__onion-ring {
		position: absolute;
		border-radius: 50%;
		aspect-ratio: 1;
		height: auto;
		border-style: solid;
		border-width: 3px;
		opacity: 0.95;
	}

	.home-export__onion-ring--1 {
		width: 100%;
		border-color: #7f1d1d;
		background: radial-gradient(circle at 35% 35%, rgba(255, 255, 255, 0.12), transparent 45%);
		box-shadow: 0 4px 20px rgba(127, 29, 29, 0.2);
	}

	.home-export__onion-ring--2 {
		width: 80%;
		border-color: #9f1239;
	}

	.home-export__onion-ring--3 {
		width: 62%;
		border-color: #be123c;
	}

	.home-export__onion-ring--4 {
		width: 44%;
		border-color: #e11d48;
	}

	.home-export__onion-ring--5 {
		width: 28%;
		border-color: #fb7185;
	}

	.home-export__onion-core {
		position: absolute;
		width: 14%;
		aspect-ratio: 1;
		border-radius: 50%;
		background: radial-gradient(circle at 30% 30%, #fff7ed, #fecdd3 60%, #fda4af 100%);
		box-shadow: inset 0 1px 2px rgba(255, 255, 255, 0.9);
	}

	.home-export__visual-caption {
		margin: 0;
		font-size: 0.7rem;
		font-weight: 800;
		text-transform: uppercase;
		letter-spacing: 0.14em;
		color: #9f1239;
		opacity: 0.85;
	}

	.home-export__main {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 0.85rem;
		min-width: 0;
	}

	.home-export__eyebrow {
		margin: 0;
		font-size: 0.75rem;
		font-weight: 800;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		color: #991b1b;
	}

	.home-export__text {
		margin: 0;
		font-size: 1.05rem;
		line-height: 1.65;
		color: #44403c;
		max-width: 40rem;
	}

	.home-export__countries {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-wrap: wrap;
		gap: 0.45rem 0.5rem;
	}

	.home-export__countries li {
		margin: 0;
		padding: 0.35rem 0.75rem;
		font-size: 0.8125rem;
		font-weight: 700;
		color: #7f1d1d;
		background: linear-gradient(180deg, #fff 0%, #fff1f2 100%);
		border: 1px solid rgba(225, 29, 72, 0.25);
		border-radius: 999px;
		box-shadow: 0 1px 2px rgba(127, 29, 29, 0.06);
	}

	.home-export__cta {
		display: grid;
		grid-template-columns: 1fr auto;
		grid-template-rows: auto auto;
		column-gap: 0.75rem;
		align-items: center;
		margin-top: 0.35rem;
		padding: 0.85rem 1.15rem;
		border-radius: 14px;
		text-decoration: none;
		background: linear-gradient(135deg, #7f1d1d 0%, #9f1239 45%, #be123c 100%);
		color: #fff;
		box-shadow: 0 4px 18px rgba(159, 18, 57, 0.35);
		border: 1px solid rgba(255, 255, 255, 0.12);
		transition:
			transform 0.15s ease,
			box-shadow 0.15s ease;
	}

	.home-export__cta:hover {
		color: #fff;
		transform: translateY(-2px);
		box-shadow: 0 8px 28px rgba(159, 18, 57, 0.4);
	}

	.home-export__cta > span:first-of-type {
		grid-column: 1;
		grid-row: 1;
		font-weight: 800;
		font-size: 1rem;
		letter-spacing: -0.02em;
	}

	.home-export__cta-sub {
		grid-column: 1;
		grid-row: 2;
		font-size: 0.72rem;
		font-weight: 600;
		opacity: 0.88;
		line-height: 1.35;
	}

	.home-export__cta svg {
		grid-column: 2;
		grid-row: 1 / span 2;
		align-self: center;
		opacity: 0.95;
	}

	@media (prefers-reduced-motion: reduce) {
		.home-export__cta:hover {
			transform: none;
		}
	}

	/* Social proof */
	.home-section--social-proof {
		background: #fff;
	}

	.home-social-lead {
		margin: 0 0 1.75rem;
		color: #57534e;
		max-width: 36rem;
		line-height: 1.65;
	}

	.home-proof-grid {
		display: grid;
		gap: 1.25rem;
	}

	@media (min-width: 900px) {
		.home-proof-grid {
			grid-template-columns: 1.2fr 0.8fr;
		}
	}

	.home-proof-card {
		background: var(--home-cream);
		border-radius: var(--home-radius-lg);
		padding: 1.5rem;
		border: 1px solid var(--color-border);
	}

	.home-proof-card--map {
		background: #fff;
		box-shadow: 0 8px 32px rgba(28, 25, 23, 0.06);
	}

	.home-proof-card .home-h3 {
		margin-bottom: 0.5rem;
	}

	.home-proof-card__text {
		margin: 0 0 1rem;
		font-size: 0.95rem;
		color: #57534e;
		line-height: 1.55;
	}

	.home-proof-embed {
		border-radius: 12px;
		overflow: hidden;
		border: 1px solid var(--color-border);
		line-height: 0;
	}

	.home-proof-embed iframe {
		width: 100%;
		height: 240px;
		display: block;
	}

	.home-proof-social-row {
		margin-top: 0.25rem;
	}

	.home-proof-social-row :global(.sil) {
		justify-content: flex-start;
	}

	/* CTA agent */
	.home-section--cta-agent {
		padding: clamp(2.5rem, 6vw, 3.5rem) 0;
	}

	.home-cta-agent {
		position: relative;
		background: linear-gradient(125deg, #9f1239 0%, #be185d 40%, #c2410c 100%);
		border-radius: var(--home-radius-lg);
		padding: clamp(1.75rem, 5vw, 2.75rem) clamp(1.5rem, 4vw, 2.5rem);
		overflow: hidden;
		color: #fff;
		text-align: center;
	}

	.home-cta-agent__decor {
		position: absolute;
		inset: 0;
		background:
			radial-gradient(circle at 20% 80%, rgba(255, 255, 255, 0.15) 0%, transparent 40%),
			radial-gradient(circle at 90% 10%, rgba(255, 255, 255, 0.12) 0%, transparent 35%);
		pointer-events: none;
	}

	.home-cta-agent .home-h2 {
		position: relative;
		max-width: 32rem;
		margin-left: auto;
		margin-right: auto;
	}

	.home-cta-agent__text {
		position: relative;
		margin: 0 auto 1.5rem;
		max-width: 36rem;
		font-size: 1.02rem;
		line-height: 1.65;
		color: rgba(255, 255, 255, 0.92);
	}

	.home-cta-agent .home-btn {
		position: relative;
	}

	/* Contact — satu kartu, grid rapi, sosial terpisah */
	.home-section--contact {
		padding-bottom: clamp(2.5rem, 6vw, 4rem);
		background: var(--home-cream);
	}

	.home-contact-page-title {
		text-align: center;
		margin-bottom: 1.5rem;
	}

	.home-contact-shell {
		width: 100%;
		background: #fff;
		border: 1px solid var(--color-border);
		border-radius: var(--home-radius-lg);
		box-shadow: 0 4px 24px rgba(28, 25, 23, 0.06);
		overflow: hidden;
	}

	.home-contact-grid {
		display: grid;
		grid-template-columns: 1fr;
	}

	.home-contact-block--location {
		border-bottom: 1px solid var(--color-border);
	}

	@media (min-width: 768px) {
		.home-contact-grid {
			grid-template-columns: 1fr 1fr;
		}

		.home-contact-block--location {
			border-bottom: none;
			border-right: 1px solid var(--color-border);
		}
	}

	.home-contact-block {
		padding: clamp(1.35rem, 4vw, 2rem) clamp(1.25rem, 4vw, 2rem);
		display: flex;
		flex-direction: column;
		gap: 1rem;
		align-items: stretch;
	}

	.home-contact-block--channels {
		background: linear-gradient(180deg, #fafaf9 0%, #fff 100%);
	}

	.home-contact-kicker {
		margin: 0;
		font-size: 0.72rem;
		font-weight: 800;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: #78716c;
	}

	.home-contact-address {
		margin: 0;
		font-style: normal;
		font-size: 1rem;
		line-height: 1.6;
		color: #44403c;
	}

	.home-contact-hours {
		margin: 0;
		padding: 0.85rem 1rem;
		background: var(--home-cream);
		border-radius: 12px;
		border: 1px solid var(--color-border);
	}

	.home-contact-hours__row {
		display: grid;
		gap: 0.25rem;
	}

	.home-contact-hours dt {
		margin: 0;
		font-size: 0.75rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		color: #78716c;
	}

	.home-contact-hours dd {
		margin: 0;
		font-size: 1.05rem;
		font-weight: 700;
		color: var(--home-slate);
	}

	.home-contact-btn {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 0.2rem;
		padding: 0.9rem 1.1rem;
		border-radius: 12px;
		text-decoration: none;
		font-weight: 700;
		transition:
			background 0.15s ease,
			border-color 0.15s ease,
			transform 0.15s ease;
		border: 2px solid transparent;
	}

	.home-contact-btn:active {
		transform: scale(0.99);
	}

	.home-contact-btn__label {
		font-size: 0.7rem;
		font-weight: 800;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		opacity: 0.9;
	}

	.home-contact-btn__value {
		font-size: 1.05rem;
		font-weight: 800;
		word-break: break-word;
	}

	.home-contact-btn--map {
		background: #fff;
		border-color: var(--color-border);
		color: var(--home-slate);
		text-align: center;
		align-items: center;
	}

	.home-contact-btn--map:hover {
		border-color: var(--home-rose);
		color: var(--home-rose);
	}

	.home-contact-btn--wa {
		background: #25d366;
		color: #fff;
		box-shadow: 0 4px 14px rgba(37, 211, 102, 0.35);
	}

	.home-contact-btn--wa:hover {
		background: #1fb855;
		color: #fff;
	}

	.home-contact-btn--wa .home-contact-btn__label {
		color: rgba(255, 255, 255, 0.9);
	}

	.home-contact-btn--mail {
		background: #f5f5f4;
		border-color: #e7e5e4;
		color: var(--home-slate);
	}

	.home-contact-btn--mail:hover {
		border-color: var(--home-rose);
		color: var(--home-rose);
		background: #fff;
	}

	.home-contact-social-wrap {
		padding: clamp(1.25rem, 3vw, 1.75rem) clamp(1.25rem, 4vw, 2rem);
		border-top: 1px solid var(--color-border);
		background: #fafaf9;
	}

	.home-contact-social-wrap :global(.sil) {
		gap: 0.75rem;
	}

	.home-contact-social-wrap :global(.sil__link) {
		width: 3.15rem;
		height: 3.15rem;
	}

	.home-contact-channels-inline {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		margin-top: 0.5rem;
	}

	.home-order-form {
		display: flex;
		flex-direction: column;
		gap: 1.15rem;
		margin-top: 0.5rem;
	}

	.form-group {
		display: flex;
		flex-direction: column;
		gap: 0.4rem;
	}

	.form-group label {
		font-size: 0.85rem;
		font-weight: 700;
		color: var(--home-slate);
	}

	.form-group input,
	.form-group textarea {
		width: 100%;
		padding: 0.85rem 1rem;
		border-radius: 10px;
		border: 1px solid #d6d3d1;
		font-family: inherit;
		font-size: 0.95rem;
		background: #fff;
		color: var(--home-slate);
		transition: border-color 0.15s ease, box-shadow 0.15s ease;
	}

	.form-group input:focus,

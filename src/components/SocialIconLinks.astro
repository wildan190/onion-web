---
/**
 * Bar ikon media sosial (bukan list). aria-label per tautan.
 */
interface Props {
	class?: string;
	variant?: 'default' | 'footer';
}

const { class: className, variant = 'default' } = Astro.props;

const items = [
	{
		network: 'tiktok' as const,
		label: 'TikTok mitrabawang.id',
		href: 'https://www.tiktok.com/@mitrabawang.id',
	},
	{
		network: 'facebook' as const,
		label: 'Facebook mitrabawang.id',
		href: 'https://www.facebook.com/share/1DUiYnV7bB/',
	},
	{
		network: 'instagram' as const,
		label: 'Instagram mitrabawang.id',
		href: 'https://www.instagram.com/mitrabawang.id?igsh=MTgwcmttMTB6ZzJ0cQ==',
	},
	{
		network: 'pinterest' as const,
		label: 'Pinterest mitrabawang.id',
		href: 'https://pin.it/6qHfRdXuR',
	},
	{
		network: 'youtube' as const,
		label: 'YouTube mitrabawang.id',
		href: 'https://www.youtube.com/@mitrabawangid',
	},
];
---

<div
	class:list={['sil', variant === 'footer' && 'sil--footer', className]}
	role="group"
	aria-label="Tautan media sosial"
>
	{
		items.map(({ network, label, href }) => (
			<a class="sil__link" href={href} target="_blank" rel="noopener noreferrer" aria-label={label}>
				{network === 'tiktok' && (
					<svg class="sil__svg" viewBox="0 0 24 24" aria-hidden="true" fill="currentColor">
						<path d="M12.525.02c1.31-.02 2.61-.01 3.918-.02.08 1.53.63 2.09 2.23 2.17 1.12.07 2.28.07 3.41.07v3.41c-1.14-.01-2.28-.03-3.41-.08-2.07-.1-2.79-.69-2.86-2.91-.04-.68-.03-1.36-.04-2.04V.02zm0 5.32v9.13c0 1.67-.7 2.79-2.24 3.35-1.63.59-3.38.45-4.43-.29-1.63-1.15-2.09-3.24-1.13-5.01.73-1.42 2.22-2.28 3.94-2.2.48.02.95.15 1.4.29V9.5c-.55-.19-1.11-.3-1.7-.29-2.51.05-4.51 2.1-4.58 4.6-.08 2.73 1.89 4.96 4.61 5.07 2.87.12 5.21-2.07 5.27-4.93V5.34c2.39 1.38 4.33.76 4.33.76V5.32c-1.47 0-2.9-.57-4.33-.34V0h-3.41v.04z" />
					</svg>
				)}
				{network === 'facebook' && (
					<svg class="sil__svg" viewBox="0 0 24 24" aria-hidden="true" fill="currentColor">
						<path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" />
					</svg>
				)}
				{network === 'instagram' && (
					<svg class="sil__svg" viewBox="0 0 24 24" aria-hidden="true" fill="currentColor">
						<path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z" />
					</svg>
				)}
				{network === 'pinterest' && (
					<svg class="sil__svg" viewBox="0 0 24 24" aria-hidden="true" fill="currentColor">
						<path d="M12.017 0C5.396 0 .029 5.367.029 11.987c0 5.079 3.158 9.417 7.618 11.174-.105-.949-.199-2.403.041-3.439.219-.937 1.406-5.957 1.406-5.957s-.359-.72-.359-1.781c0-1.663.967-2.911 2.168-2.911 1.024 0 1.518.769 1.518 1.688 0 1.029-.653 2.567-.992 3.992-.285 1.193.6 2.165 1.775 2.165 2.128 0 3.768-2.245 3.768-5.487 0-2.861-2.063-4.869-5.008-4.869-3.41 0-5.409 2.562-5.409 5.199 0 1.033.394 2.143.889 2.741.097.118.112.221.085.345-.09.375-.293 1.199-.334 1.363-.053.225-.172.271-.402.165-1.495-.69-2.433-2.878-2.433-4.646 0-3.776 2.748-7.252 7.92-7.252 4.158 0 7.392 2.967 7.392 6.923 0 4.135-2.607 7.462-6.233 7.462-1.214 0-2.354-.629-2.758-1.379l-.749 2.848c-.269 1.045-1.004 2.352-1.498 3.146 1.123.345 2.306.535 3.55.535 6.607 0 11.985-5.365 11.985-11.987C23.97 5.39 18.592.026 11.985.026L12.017 0z" />
					</svg>
				)}
				{network === 'youtube' && (
					<svg class="sil__svg" viewBox="0 0 24 24" aria-hidden="true" fill="currentColor">
						<path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z" />
					</svg>
				)}
			</a>
		))
	}
</div>

<style>
	.sil {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: center;
		gap: 0.65rem;
	}

	.sil--footer {
		justify-content: flex-start;
		gap: 0.5rem;
	}

	.sil__link {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 3rem;
		height: 3rem;
		border-radius: 12px;
		color: #44403c;
		background: #fff;
		border: 1px solid var(--color-border);
		text-decoration: none;
		transition:
			color 0.15s ease,
			background 0.15s ease,
			border-color 0.15s ease,
			transform 0.15s ease;
	}

	.sil__link:hover {
		color: var(--color-accent);
		border-color: rgba(159, 18, 57, 0.35);
		background: var(--color-accent-soft);
	}

	.sil__link:active {
		transform: scale(0.96);
	}

	.sil--footer .sil__link {
		width: 2.65rem;
		height: 2.65rem;
		border-radius: 10px;
		background: #fafaf9;
	}

	.sil--footer .sil__link:hover {
		background: #fff;
	}

	.sil__svg {
		width: 1.35rem;
		height: 1.35rem;
		display: block;
	}

	.sil--footer .sil__svg {
		width: 1.2rem;
		height: 1.2rem;
	}

	@media (prefers-reduced-motion: reduce) {
		.sil__link:active {
			transform: none;
		}
	}
</style>

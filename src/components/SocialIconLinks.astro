---
/**
 * Bar ikon media sosial (Iconify Simple Icons via astro-icon).
 */
import { Icon } from 'astro-icon/components';

interface Props {
	class?: string;
	variant?: 'default' | 'footer';
}

const { class: className, variant = 'default' } = Astro.props;

const items = [
	{
		icon: 'simple-icons:tiktok' as const,
		label: 'TikTok mitrabawang.id',
		href: 'https://www.tiktok.com/@mitrabawang.id',
	},
	{
		icon: 'simple-icons:facebook' as const,
		label: 'Facebook mitrabawang.id',
		href: 'https://www.facebook.com/share/1DUiYnV7bB/',
	},
	{
		icon: 'simple-icons:instagram' as const,
		label: 'Instagram mitrabawang.id',
		href: 'https://www.instagram.com/mitrabawang.id?igsh=MTgwcmttMTB6ZzJ0cQ==',
	},
	{
		icon: 'simple-icons:pinterest' as const,
		label: 'Pinterest mitrabawang.id',
		href: 'https://pin.it/6qHfRdXuR',
	},
	{
		icon: 'simple-icons:youtube' as const,
		label: 'YouTube mitrabawang.id',
		href: 'https://www.youtube.com/@mitrabawangid',
	},
];
---

<div
	class:list={['sil', variant === 'footer' && 'sil--footer', className]}
	role="group"
	aria-label="Tautan media sosial"
>
	{
		items.map(({ icon: iconName, label, href }) => (
			<a class="sil__link" href={href} target="_blank" rel="noopener noreferrer" aria-label={label}>
				<Icon name={iconName} class="sil__svg" aria-hidden="true" />
			</a>
		))
	}
</div>

<style>
	.sil {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		justify-content: center;
		gap: 0.65rem;
	}

	.sil--footer {
		justify-content: flex-start;
		gap: 0.5rem;
	}

	.sil__link {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 3rem;
		height: 3rem;
		border-radius: 12px;
		color: #44403c;
		background: #fff;
		border: 1px solid var(--color-border);
		text-decoration: none;
		transition:
			color 0.15s ease,
			background 0.15s ease,
			border-color 0.15s ease,
			transform 0.15s ease;
	}

	.sil__link:hover {
		color: var(--color-accent);
		border-color: rgba(159, 18, 57, 0.35);
		background: var(--color-accent-soft);
	}

	.sil__link:active {
		transform: scale(0.96);
	}

	.sil--footer .sil__link {
		width: 2.65rem;
		height: 2.65rem;
		border-radius: 10px;
		background: #fafaf9;
	}

	.sil--footer .sil__link:hover {
		background: #fff;
	}

	.sil__link :global(svg) {
		width: 1.35rem;
		height: 1.35rem;
		display: block;
	}

	.sil--footer .sil__link :global(svg) {
		width: 1.2rem;
		height: 1.2rem;
	}

	@media (prefers-reduced-motion: reduce) {
		.sil__link:active {
			transform: none;
		}
	}
</style>

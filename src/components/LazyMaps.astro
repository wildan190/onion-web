---
/**
 * Lazy Loading Google Maps Iframe Component
 * Defers loading until element is in viewport
 * Reduces initial page load by ~1s
 */

interface Props {
  src: string;
  title?: string;
  width?: string;
  height?: string;
}

const { src, title = "Google Maps", width = "600", height = "350" } = Astro.props;
---

<div class="maps-lazy-wrapper" data-maps-embed>
  <iframe
    {title}
    {src}
    {width}
    {height}
    style="border:0"
    allowfullscreen=""
    loading="lazy"
    referrerpolicy="no-referrer-when-downgrade">
  </iframe>
</div>

<script>
  // Load Google Maps scripts only when iframe is in viewport
  const mapsElements = document.querySelectorAll('[data-maps-embed]');
  
  if ('IntersectionObserver' in window) {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          // Preload Google Maps scripts when visible
          const link = document.createElement('link');
          link.rel = 'prefetch';
          link.href = 'https://maps.googleapis.com/maps/api/js';
          document.head.appendChild(link);
          observer.unobserve(entry.target);
        }
      });
    }, { rootMargin: '50px' });

    mapsElements.forEach((el) => observer.observe(el));
  }
</script>

<style>
  .maps-lazy-wrapper {
    position: relative;
    width: 100%;
    overflow: hidden;
    border-radius: 12px;
  }

  .maps-lazy-wrapper iframe {
    width: 100%;
    height: 100%;
    display: block;
  }
</style>

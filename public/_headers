/* Cache assets with hashes for 1 year (aggressive caching) */
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

/* Cache images for 30 days */
/assets/img/*
  Cache-Control: public, max-age=2592000, stale-while-revalidate=604800

/* Cache fonts for 1 year */
/assets/fonts/*
  Cache-Control: public, max-age=31536000, immutable

/* HTML - short cache with must-revalidate */
/*.html
  Cache-Control: public, max-age=3600, must-revalidate, stale-while-revalidate=86400

/* Default for everything else (HTML) */
/
  Cache-Control: public, max-age=3600, must-revalidate, stale-while-revalidate=86400

/* Compression headers */
/*
  Content-Encoding: gzip
